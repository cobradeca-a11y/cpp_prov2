# CPP — configuração

OCR_ENGINE=tesseract
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

AUDIVERIS_CMD=C:\Program Files\Audiveris\Audiveris.exe

CPP_BACKEND_HOST=0.0.0.0
CPP_BACKEND_PORT=8787

# OCR especializado em cifras via GPT-4o (audit-69)
# Ative para reconhecimento preciso de chord symbols (Cm7, Ab/Eb, F#m7sus4, etc.)
# Custo estimado: ~$0.01-0.03 por partitura de 2 páginas
# CHORD_OCR_ENGINE=gpt4o
# OPENAI_API_KEY=sk-...

# Google Cloud Vision (alternativa ao tesseract)
# OCR_ENGINE=google_vision
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json
